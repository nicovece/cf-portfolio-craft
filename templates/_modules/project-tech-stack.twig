{% set category = category|default(['essential', 'fullList']) %}
{% set wrapperClasses = wrapperClasses|default('') %}
{% set itemClasses = itemClasses|default('') %}
{% set itemsHaveDescription = itemsHaveDescription|default(false) %}
{% set itemsSeparator = itemsSeparator|default(',') %}
{% set groupByStack = groupByStack|default(false) %}
{% set groupHeadingClasses = groupHeadingClasses|default('text-fs-medium mt-12 mb-4') %}

{% macro techList(items, wrapperClasses, itemClasses, itemsHaveDescription, itemsSeparator, revealItem) %}
	<ul class="{{ wrapperClasses }}" {% if revealItem %} data-reveal-item {% endif %}>
		{% for item in items %}
			<li class="{{ itemClasses }}">
				<strong class="font-medium">{{ item.techItemName }}</strong>
				{% if
					itemsHaveDescription and item.techItemDescription %}
					<span>({{ item.techItemDescription }})</span>
				{% endif -%}
				{% if not loop.last and itemsSeparator %}
					{{ itemsSeparator }}
				{% endif %}
			</li>
		{% endfor %}
	</ul>
{% endmacro %}
{% import _self as helpers %}

{% set categoryFilter = category is iterable ? category : [category] %}
{% set techStackItems =
	entry.techStackItems.eagerly().all()|filter(item => item.techItemCategory.value in categoryFilter)
%}

{% if techStackItems|length %}
	{% if groupByStack %}
		{% set stackOptions = craft.app.fields.getFieldByHandle('techItemStack').options %}
		{% set presentOptions = stackOptions|filter(option =>
			techStackItems|filter(item => item.techItemStack.value == option.value)|length
		) %}
		{% if presentOptions|length > 1 %}
			{% for option in presentOptions %}
				{% set groupItems = techStackItems|filter(item => item.techItemStack.value == option.value) %}
				<div data-reveal-item>
					<h6 class="{{ groupHeadingClasses }}">{{ option.label }}</h6>
					{{ helpers.techList(groupItems, wrapperClasses, itemClasses, itemsHaveDescription, itemsSeparator, false) }}
				</div>
			{% endfor %}
		{% else %}
			{{ helpers.techList(techStackItems, wrapperClasses, itemClasses, itemsHaveDescription, itemsSeparator, true) }}
		{% endif %}
	{% else %}
		{{ helpers.techList(techStackItems, wrapperClasses, itemClasses, itemsHaveDescription, itemsSeparator, true) }}
	{% endif %}
{% endif %}
